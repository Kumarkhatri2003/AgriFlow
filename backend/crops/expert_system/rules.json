  },
  {
    "rule_id": "NPK_BALANCED_HIGH",
    "name": "High NPK balance boosts score",
    "conditions": [
      {"fact": "n", "operator": "between", "value": ["crop.n_need_min", "crop.n_need_max"]},
      {"fact": "p", "operator": "between", "value": ["crop.p_need_min", "crop.p_need_max"]},
      {"fact": "k", "operator": "between", "value": ["crop.k_need_min", "crop.k_need_max"]}
    ],
    "conclusion": {"fact": "crop_score_adjustment", "value": {"adjustment": 10}},
    "certainty": 0.90,
    "priority": 8,
    "category": "soft",
    "explanation": "Soil NPK levels are perfectly balanced for this crop"
  },
  {
    "rule_id": "N_EXTREME_DEFICIENCY",
    "name": "Extreme N deficiency penalty",
    "conditions": [
      {"fact": "n", "operator": "lt", "value": "crop.n_need_min * 0.3"}
    ],
    "conclusion": {"fact": "crop_score_adjustment", "value": {"adjustment": -15}},
    "certainty": 0.85,
    "priority": 7,
    "category": "soft",
    "explanation": "Nitrogen level is critically low",
    "mitigation": "Apply 60-80 kg/ha urea or 5-6 tons/ha compost before planting"
  },
  {
    "rule_id": "P_EXTREME_DEFICIENCY",
    "name": "Extreme P deficiency penalty",
    "conditions": [
      {"fact": "p", "operator": "lt", "value": "crop.p_need_min * 0.3"}
